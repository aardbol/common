{
  "name": "bundle-verifier",
  "version": "0.0.1",
  "description": "GitHub Action to verify the committed bundle is up-to-date with the source",
  "main": "index.js",
  "author": "Red Hat",
  "license": "MIT",
  "scripts": {
    "compile": "tsc -p .",
    "bundle": "ncc build src/index.ts --source-map --minify",
    "lint": "eslint . --max-warnings=0"
  },
  "devDependencies": {
    "@redhat-actions/eslint-config": "^1.3.2",
    "@redhat-actions/tsconfig": "^1.2.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vercel/ncc": "^0.44.0",
    "eslint": "^8.57.0",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.0"
  }
}
